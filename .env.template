# blobcache local environment template.
#
# Copy to `.env` (gitignored) and fill in the values for your test setup.
# Bench scripts (`bench/*.sh`, `benchmarks/bench.sh`) and the storage-access
# helper (`deploy/storage-access.sh`) source `.env` from the repo root.
#
#   cp .env.template .env
#   $EDITOR .env
#
# All variables are required unless marked OPTIONAL.

# --- Azure storage ---------------------------------------------------------

# Storage account that holds the test blobs.
STORAGE_ACCOUNT=

# Resource group that owns STORAGE_ACCOUNT (used by storage-access.sh).
RESOURCE_GROUP=

# Container within STORAGE_ACCOUNT to mount.
CONTAINER=models

# Blob-name prefix to expose under the mount (trailing slash, may be empty).
MODEL_PREFIX=

# --- Azure auth ------------------------------------------------------------

# Client-id of the user-assigned MSI with `Storage Blob Data Reader`
# (or higher) on STORAGE_ACCOUNT. The blobcached pods consume this via
# AZURE_CLIENT_ID; bench scripts forward it for direct azcp invocations.
AZURE_CLIENT_ID=

# --- Kubernetes ------------------------------------------------------------

# Namespace the blobcached DaemonSet lives in.
NAMESPACE=blobcache

# AKS agent-pool node-label value to pin the DaemonSets to.
AGENT_POOL=

# Node-label key/value used to opt nodes into the test DaemonSet.
TEST_NODE_LABEL_KEY=blobcache.test/enabled
TEST_NODE_LABEL_VALUE=true

# --- OPTIONAL: gossip seed IPs (only needed by some bench scripts) ---------
# Comma-separated list of `http://IP:7771` URLs for the bench scripts that
# pre-render per-pod TOML with seed addresses baked in. Leave empty to let
# the scripts discover seeds from the running pods.
GOSSIP_SEEDS=

# --- OPTIONAL: stable seed-holding nodes ----------------------------------
# Comma-separated list of node names that hold the GOSSIP_SEEDS IPs. Used by
# bench/matrix.sh and bench/azcp-matrix.sh to keep these nodes labeled at
# every N>=1 so cluster bootstrap stays valid. If unset, the scripts default
# to the first 3 nodes returned by `kubectl get nodes -l agentpool=$AGENT_POOL`.
#SEED_NODES=
